PORT=5001
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/smartbazaar
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=7d
CLIENT_URL=https://your-vercel-app.vercel.app

# Admin credentials (used for seeding)
ADMIN_EMAIL=admin@smartbazaar.com
ADMIN_PASSWORD=Admin@1234

# Cloudinary (for product image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Nodemailer (optional — app works without this)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
ALERT_EMAIL=alerts@smartbazaar.com
